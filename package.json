{
  "name": "monorepo-v4",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:agent": "turbo run dev --filter=agent --filter=agents",
    "dev:web": "turbo run dev --filter=web --filter=@mspbyte/shared",
    "dev:pipeline": "turbo run dev --filter=ingestion --filter=projection --filter=normalize",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:clean": "docker compose -f infra/docker-compose.yml down -v",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "nitro": "npm:nitro-nightly@latest",
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "backend/*",
    "packages/*"
  ]
}
