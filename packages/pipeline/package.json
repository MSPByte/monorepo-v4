{
  "name": "@mspbyte/pipeline",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*/index.ts",
      "import": "./dist/*/index.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@mspbyte/drizzle": "*",
    "@mspbyte/shared": "*",
    "bullmq": "^5.65.1",
    "drizzle-orm": "^1.0.0-beta.22",
    "ioredis": "^5.8.2"
  },
  "devDependencies": {
    "@mspbyte/typescript-config": "*",
    "@types/node": "^25.9.3",
    "typescript": "^5.4.0"
  }
}
