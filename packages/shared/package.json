{
  "name": "@mspbyte/shared",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*/index.ts",
      "import": "./dist/*/index.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@mspbyte/typescript-config": "*",
    "typescript": "^5.4.0"
  }
}
