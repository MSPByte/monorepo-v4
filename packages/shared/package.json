{
  "name": "@mspbyte/shared",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "import": "./dist/types/*.js"
    },
    "./config/*": {
      "types": "./src/config/*/index.ts",
      "import": "./dist/config/*/index.js"
    },
    "./*": {
      "types": "./src/*/index.ts",
      "import": "./dist/*/index.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@mspbyte/typescript-config": "*",
    "@types/node": "^25.9.3",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@mspbyte/connectors": "*",
    "@mspbyte/encryption": "*",
    "@mspbyte/pipeline": "*",
    "zod": "^4.4.3"
  }
}
